Options -Indexes
ServerSignature Off

# ============================================
# 1. HTTPS FORCE - fixes audit item
# ============================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ============================================
# 2. WWW FORCE - fixes duplicate domain issue
# ============================================
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ============================================
# 2.5 CITY PAGE REDIRECTS - 301 Redirects for SEO Consistency
# ============================================
RewriteRule ^packers-movers/delhi/?$ https://www.panyaglobal.in/packers-movers-delhi [R=301,L]
RewriteRule ^packers-movers/gurgaon/?$ https://www.panyaglobal.in/packers-movers-gurgaon [R=301,L]
RewriteRule ^packers-movers/noida/?$ https://www.panyaglobal.in/packers-movers-noida [R=301,L]
RewriteRule ^packers-movers-gurugram/?$ https://www.panyaglobal.in/packers-movers-gurgaon [R=301,L]

# ============================================
# 3. REMOVE TRAILING SLASH - URL consistency
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# ============================================
# 4. REACT SPA ROUTING - city pages won't 404
# ============================================
# Serve API directly (PHP files)
RewriteRule ^api/ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# ============================================
# 5. GZIP COMPRESSION - fixes audit item
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE font/woff
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ============================================
# 6. BROWSER CACHING - performance score fix
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                  "access plus 1 hour"
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"
</IfModule>

# ============================================
# 7. CACHE-CONTROL HEADERS
# ============================================
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|jpg|jpeg|png|svg|woff2|woff|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================
# 8. CHARSET
# ============================================
AddDefaultCharset UTF-8

# ============================================
# 9. SECURITY HEADERS - bonus SEO trust signal
# ============================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
